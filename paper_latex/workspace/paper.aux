\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Calibration performance on five text classification datasets using pre-trained transformer embeddings. Values are ECE (lower is better). Bold indicates best (lowest) ECE per dataset.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:main_results}{{2}{8}{Calibration performance on five text classification datasets using pre-trained transformer embeddings. Values are ECE (lower is better). Bold indicates best (lowest) ECE per dataset}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Expected Calibration Error (ECE, lower is better) for uncalibrated baseline, temperature scaling (TS), and Thermodynamic Entropy Calibration (TEC) across five text classification datasets. TEC outperforms TS on QNLI and DBpedia, while TS outperforms TEC on SST-2, AG News, and MNLI. Both methods significantly improve over uncalibrated baseline on all datasets.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:ece_comparison}{{2}{8}{Expected Calibration Error (ECE, lower is better) for uncalibrated baseline, temperature scaling (TS), and Thermodynamic Entropy Calibration (TEC) across five text classification datasets. TEC outperforms TS on QNLI and DBpedia, while TS outperforms TEC on SST-2, AG News, and MNLI. Both methods significantly improve over uncalibrated baseline on all datasets}{figure.2}{}}
\citation{Kull2019}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ECE decomposition by easy/hard splits for QNLI and DBpedia, where TEC outperforms temperature scaling. Hard examples have substantially higher uncalibrated ECE, and TEC's per-sample adjustment provides greater improvement for this subset.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:ece_decomposition}{{3}{9}{ECE decomposition by easy/hard splits for QNLI and DBpedia, where TEC outperforms temperature scaling. Hard examples have substantially higher uncalibrated ECE, and TEC's per-sample adjustment provides greater improvement for this subset}{figure.3}{}}
